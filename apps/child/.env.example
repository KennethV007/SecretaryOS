# Discord credentials for the child bot (separate from the main SecretaryOS bot)
CHILD_DISCORD_BOT_TOKEN=
CHILD_DISCORD_CLIENT_ID=
CHILD_DISCORD_GUILD_ID=          # optional, for guild-scoped slash commands
CHILD_DISCORD_CHANNEL_ID=        # the channel the child bot talks in
CHILD_DISCORD_ALLOWED_USER_IDS=  # comma-separated, empty = allow all

# Child persona settings
CHILD_NAME=Pip
CHILD_AGE=9

# Ollama connection
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_MS=30000

# Memory store (JSON file paths on disk)
CHILD_MEMORY_DIR=./data/child-memory
CHILD_CONVERSATION_MAX_TURNS=40
CHILD_FACTS_MAX=100

# Proactive scheduler
CHILD_PROACTIVE_ENABLED=true
CHILD_PROACTIVE_INTERVAL_MS=3600000
CHILD_BEDTIME_HOUR=21
CHILD_WAKEUP_HOUR=7
CHILD_PROACTIVE_USE_OLLAMA=false
