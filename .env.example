POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/secretary_os
REDIS_URL=redis://localhost:6379
API_BASE_URL=http://127.0.0.1:3001
PERSONA_PACK_ROOT=data/persona-packs
ACTIVE_CHARACTER_PATH=data/active-character.json
SETTINGS_PATH=config/settings.json

# Auth / sessions
SESSION_SECRET=change_me
INTERNAL_API_KEY=change_me
WORKER_CONCURRENCY=1

# Codex MCP / local runtime
CODEX_MCP_COMMAND=/opt/homebrew/bin/codex
CODEX_MCP_ARGS=exec --skip-git-repo-check --color never -m {model}
CODEX_SKILL_ROOT=
CODEX_DEFAULT_MODEL=gpt-5.3-codex
CODEX_ASSISTANT_MODEL=gpt-5.3-codex-spark
CODEX_PLANNER_MODEL=gpt-5.3-codex
CODEX_AFTER_HOURS_MODEL=gpt-5.3-codex
CODEX_MAX_PARALLEL_TASKS=3
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_ALLOWED_USER_IDS=

# Voice
CHATTERBOX_BASE_URL=http://localhost:8001
STT_PROVIDER=
STT_API_KEY=

# Memory
MEMPALACE_ENABLED=true
MEMPALACE_COMMAND=python3
MEMPALACE_ARGS=-m mempalace
MEMORY_DEFAULT_TOP_K=8
MEMORY_WRITE_ENABLED=true

# Git / GitHub
GITHUB_TOKEN=
DEFAULT_GIT_AUTHOR_NAME=SecretaryOS
DEFAULT_GIT_AUTHOR_EMAIL=secretary@example.com

# Filesystem safety
ALLOWED_WORKSPACE_ROOTS=/Users/macstudio/projects,/Users/macstudio/Documents
SAFE_DELETE_TRASH_DIR=/Users/macstudio/.secretary-trash

# Proactive behavior
PROACTIVE_ENABLED=true
PROACTIVE_QUIET_HOURS_START=23
PROACTIVE_QUIET_HOURS_END=8
